// Copy this file to Signing.xcconfig (gitignored) and fill in the real values.
// Referenced from iosApp/project.yml via `configFiles:`.
//
// DEVELOPMENT_TEAM is the 10-char Apple Team ID — find it in App Store
// Connect → Membership, or at developer.apple.com/account.
//
// PROVISIONING_PROFILE_SPECIFIER is normally not set here — fastlane's
// sigh action resolves and injects it via xcargs at archive time. If you
// want to do local Release archives in Xcode without fastlane, uncomment
// the line below and fill in the profile name shown in Xcode → Settings
// → Accounts → Manage Profiles.

DEVELOPMENT_TEAM = ABCDE12345
CODE_SIGN_STYLE = Manual
CODE_SIGN_IDENTITY = Apple Distribution
// PROVISIONING_PROFILE_SPECIFIER = Fieldshootingtimer App Store
