# Generated by XcodeGen from project.yml — do not commit.
iosApp.xcodeproj/

# Xcode user/build cruft
xcuserdata/
DerivedData/
build/
*.xcuserstate

# Per-developer signing (team ID, profile name). Templated alongside.
Configuration/Signing.xcconfig

# Fastlane local credentials + state (App Store Connect API key path, run logs).
fastlane/.env
fastlane/report.xml
fastlane/Preview.html
fastlane/test_output/
fastlane/README.md

# Code-signing artifacts that fastlane / Xcode may drop in this dir during an
# archive. All are reproducible (fetchable via ASC API) and the .p12 contains
# the private key — keep them out of the repo entirely.
*.cer
*.certSigningRequest
*.mobileprovision
*.p12
