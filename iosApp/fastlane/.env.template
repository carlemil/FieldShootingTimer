# Copy this file to iosApp/fastlane/.env (gitignored) and fill in real values.
# fastlane auto-loads .env from the same directory as the Fastfile.

# --- App Store Connect API key (preferred over Apple ID login) -----------
# Create at https://appstoreconnect.apple.com/access/api with "App Manager" role.
# Download the .p8 file once; ASC won't show it again.
ASC_KEY_ID=ABCDE12345
ASC_ISSUER_ID=12345678-1234-1234-1234-123456789012
ASC_KEY_PATH=/absolute/path/to/AuthKey_ABCDE12345.p8

# --- Identity (used by Appfile + sanity checks) --------------------------
FASTLANE_APPLE_ID=you@example.com
FASTLANE_TEAM_ID=ABCDE12345
